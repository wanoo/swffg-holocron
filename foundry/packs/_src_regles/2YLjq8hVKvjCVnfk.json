      "_id": "l1bsSIFpLaQrcZhi",
      "name": "Combats à deux Armes",
      "sort": 80,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<h2>Test combiné de compétence des deux armes</h2><p><strong>Difficulté :</strong></p><ul><li><p>+[di] si même compétence</p></li><li><p>+[di][di] sinon</p></li></ul><blockquote><p>[su] = l’arme principale atteint la cible</p><p>[ad][ad] / [tr] = l’arme secondaire aussi</p></blockquote>",

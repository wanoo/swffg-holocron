    {
      "_id": "zLtAL5LRW2mtk1fx",
      "name": "Soin Médecine/Mécanique",
      "sort": 170,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<ul><li><p>[su] : Guérit 1 blessure</p></li><li><p>[ad] : 1 stress</p></li><li><p>[tr] : Guérit 1 blessure supplémentaire ou 1 blessure critique</p></li><li><p>[th]: +1 stress</p></li><li><p>[de] : +1 blessure</p></li><li><p><strong>Se guérir soi-même :</strong> humain +[di][di] ; droid +[di]</p></li><li><p><strong>Sans outils :</strong> +[di]</p></li></ul><h3>Difficulté</h3><div><table style=\"text-align:center\"><thead><tr><th><p>Blessures</p></th><th>Difficulté</th></tr></thead><tbody><tr><td><p>Points de blessure ≤ ½ Seuil</p></td><td>[di]</td></tr><tr><td><p>Points de blessure &gt; ½ Seuil</p></td><td>[di][di]</td></tr><tr><td><p>Points de blessure ≥ Seuil</p></td><td>[di][di][di]</td></tr><tr><td colspan=\"2\"><p><strong>max. 1 test / personnage / rencontre</strong></p></td></tr><tr><td><p>Soin d’une blessure critique</p></td><td>Gravité de la blessure ([di] ~ [di][di][di][di])</td></tr><tr><td colspan=\"2\"><p><strong>max. 1 test / semaine / blessure critique</strong></p></td></tr></tbody></table></div>",
        "format": 1
      },

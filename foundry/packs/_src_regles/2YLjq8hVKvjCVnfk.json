    {
      "_id": "BNOOvJ4H25B2lRoE",
      "name": "Seuil de blessures",
      "sort": 70,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<p><strong>Point de stress &gt; seuil de stress :</strong> </p><p>neutralisé </p><p><strong>Point de blessure &gt; seuil de blessure :</strong> </p><p>neutralisé + blessure critique </p><p><strong>max. blessure recevable:</strong></p><p>Seuil de blessure × 2 </p><p><strong>blessure critique :</strong> </p><p>1d100 + 10 × nb. blessure critique déjà présente + 10 × nb. mod \"Critique\" sur l'arme</p><p><em>une blessure critique reste présente tant qu’elle n’est pas soignée (même si ses « effets » ont disparu)</em></p>",
        "format": 1

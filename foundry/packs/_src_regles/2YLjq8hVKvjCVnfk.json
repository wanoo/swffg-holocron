    {
      "_id": "jMnJy8FukkBPBJiA",
      "name": "Armes Improvisée",
      "sort": 100,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<h2>Test de corps à corps ( +[th] automatique )</h2><p>Dommages = vigueur + bonus (cf. ci-dessous)</p><blockquote><p>critique de : 5<br />sur [th][th] / [de] l’arme improvisée casse</p></blockquote><div><table><thead><tr style=\"border-top:1px dotted #aaa\"><th>Taille</th><th>Dommage</th><th>Encombrement</th><th>Spécial</th><th>Exemples</th></tr></thead><tbody><tr style=\"border-top:1px dotted #aaa\"><td><p>Petite</p></td><td>Pugilat +1</td><td>1</td><td>-</td><td>Bouteille, pierre (taille poing), hydrocompresseur</td></tr><tr style=\"border-top:1px dotted #aaa\"><td><p>Moyen</p></td><td>Pugilat +2</td><td>3</td><td>Encombrant 2</td><td>Pierre (deux mains), chaise, écran holo-vidéo</td></tr><tr style=\"border-top:1px dotted #aaa\"><td><p>Grand</p></td><td>Pugilat +3</td><td>4</td><td>Encombrant 4</td><td>Pelle, grosse branche d’arbre, table, caisse</td></tr></tbody></table></div>",
        "format": 1
      },
      "system": {},

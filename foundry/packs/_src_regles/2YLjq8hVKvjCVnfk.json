    {
      "_id": "pYA5I9DbS123Ardk",
      "name": "Test de Combat",
      "sort": 60,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<h2>Distance</h2><ul><li><p><span style=\"font-family:sans-serif\">Test d’<strong>armes légères</strong>, <strong>lourdes</strong> ou <strong>artillerie</strong></span></p></li></ul><h2>Contact </h2><ul><li><p><span style=\"font-family:sans-serif\">Test de <strong>corps à corps</strong>, <strong>pugilat</strong> ou <strong>sabreLaser</strong></span></p></li></ul><h2>Difficulté</h2><div><table style=\"text-align:center\"><thead><tr style=\"border-top:1px dotted #aaa\"><th>Portée</th><th>Difficulté</th></tr></thead><tbody><tr style=\"border-top:1px dotted #aaa\"><td><p>Contact</p></td><td>[di][di]</td></tr><tr style=\"border-top:1px dotted #aaa\"><td><p>Contact avec armes légères*</p></td><td>[di][di]</td></tr><tr style=\"border-top:1px dotted #aaa\"><td><p>Contact avec armes lourdes*</p></td><td>[di][di][di]</td></tr><tr style=\"border-top:1px dotted #aaa\"><td><p>Contact avec artillerie*</p></td><td>Impossible</td></tr><tr style=\"border-top:1px dotted #aaa\"><td><p>Courte</p></td><td>[di]</td></tr><tr style=\"border-top:1px dotted #aaa\"><td><p>Moyenne</p></td><td>[di][di]</td></tr><tr style=\"border-top:1px dotted #aaa\"><td>Longue</td><td>[di][di][di]</td></tr><tr style=\"border-top:1px dotted #aaa\"><td>Extrême</td><td>[di][di][di][di]</td></tr></tbody></table></div><h2>Défense</h2><p><span style=\"font-family:sans-serif\">+[se] par valeur de défense (à distance / mêlée) de la cible</span></p><h2>Tir à distance sur cible au contact avec une autre</h2><p>Améliorer 1 [di] (devient [ch]) du test à distance</p><blockquote><p>[de] Touche la mauvaise personne</p></blockquote><h2>Nombre de Blessure</h2><p>Dommage de l'arme + [su] - Encaissement</p>",
        "format": 1
      },
      "system": {},
      "image": {},

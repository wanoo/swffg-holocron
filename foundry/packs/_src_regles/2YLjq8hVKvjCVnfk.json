    {
      "_id": "mgoQPS1UTDg9XN49",
      "name": "Effets Continus",
      "sort": 150,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<blockquote><p>Les effets continus peuvent se cumuler</p></blockquote><ul><li><p><strong>Désorienté (disoriented) :</strong> +[se] à tous les tests</p></li><li><p><strong>immobilisé (immobilized) :</strong> ne peut plus faire de manœuvre</p></li><li><p><strong>Étourdi (staggered) :</strong> ne peut plus faire d’actions jusqu’à la fin du prochain tour</p></li><li><p><strong>Neutralisé :</strong> tombe inconscient et ne peut plus agir. Le personnage reste neutralisé tant qu’il n’est pas soigné</p></li></ul>",
        "format": 1
      },
      "system": {},
      "image": {},
      "video": {

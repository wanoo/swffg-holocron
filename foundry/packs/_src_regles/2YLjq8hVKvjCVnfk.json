    {
      "_id": "diKRpji6BfZWs7gD",
      "name": "Voler",
      "sort": 140,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<h2>Survoler :</h2><ul><li><p>Ignore la difficulté du terrain</p></li><li><p>Doit rester à portée moyenne du sol</p></li></ul><h2>Vol aérodynamique :</h2><ul><li><p>Utilise une manœuvre par tour pour maintenir le vol</p></li><li><p>Peut aller de portée longue à courte en une manœuvre</p></li></ul>",
        "format": 1
      },
      "system": {},

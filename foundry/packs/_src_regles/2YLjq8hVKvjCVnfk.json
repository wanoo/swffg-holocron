        "content": "<ul><li><p><span style=\"font-family:sans-serif\">Exécuter une manœuvre en plus</span></p></li><li><p><span style=\"font-family:sans-serif\">Activer une capacité</span></p></li><li><p><span style=\"font-family:sans-serif\">Activer un pouvoir de la Force</span></p></li><li><p><span style=\"font-family:sans-serif\">Test de compétence</span></p></li><li><p><span style=\"font-family:sans-serif\">Test de combat</span></p></li><li><p><span style=\"font-family:sans-serif\">Autres tâches complexes</span></p></li></ul>",

    {
      "name": "Manœuvres",
      "sort": 10,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<table><tbody><tr><td>Viser</td><td>+[bo] à la prochaine attaque (max [bo][bo] sur 2 manœuvres) · viser une partie précise : [se][se], réduit à [se] avec 2 manœuvres</td></tr><tr><td>Assister</td><td>+[bo] au test d'un allié au contact (cumulable)</td></tr><tr><td>Posture défensive</td><td>[se] à ses attaques CàC contre +1 défense de mêlée</td></tr><tr><td>Se déplacer</td><td>1 manœuvre : contact↔courte, courte↔moyenne · 2 manœuvres : moyenne↔longue, longue↔extrême · terrain difficile : ×2</td></tr><tr><td>Se jeter à terre</td><td>[se] aux tirs qui vous visent, [bo] aux attaques CàC qui vous visent</td></tr><tr><td>Gérer l'équipement</td><td>Dégainer, recharger, basculer en étourdissant…</td></tr><tr><td>Interagir</td><td>Ouvrir une porte, s'abriter (+1 défense à distance)…</td></tr><tr><td>Monter/descendre</td><td>Véhicule ou monture (test Survie Moyen ([di][di]) pour une monture)</td></tr></tbody></table>",
        "format": 1
      },

    {
      "_id": "P2E2go1u1DdtbZdq",
      "name": "Tomber",
      "sort": 10,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<p><span style=\"text-decoration:underline\"><span style=\"text-decoration:underline\">Test d’</span><strong><span style=\"text-decoration:underline\">Athlétisme</span></strong><span style=\"text-decoration:underline\"> / </span><strong><span style=\"text-decoration:underline\">Coordination</span></strong><span style=\"text-decoration:underline\"> ([di][di]) :</span></span></p><ul><li><p>Chaque [su] = -1 dommage</p></li><li><p>Chaque [ad] = -1 stress</p></li><li><p>[tr] = Réduit la chute d’un niveau de portée</p></li></ul><table style=\"text-align:center\"><thead><tr style=\"border-bottom:1px solid #999\"><th>Portée</th><th>Dommage</th><th>Stress</th></tr></thead><tbody><tr style=\"border-bottom:1px solid #999\"><td>Courte</td><td>10</td><td>10</td></tr><tr style=\"border-bottom:1px solid #999\"><td>Moyenne</td><td>30</td><td>20</td></tr><tr style=\"border-bottom:1px solid #999\"><td>Longue</td><td>Neutralisé, 1 blessure critique <strong>+50</strong></td><td>30</td></tr><tr style=\"border-bottom:1px solid #999\"><td>Extrême</td><td>Neutralisé, 1 blessure critique <strong>+75</strong></td><td>40</td></tr></tbody></table>",
        "format": 1
      },

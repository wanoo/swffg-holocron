    {
      "_id": "P9BNa3viadqB48gv",
      "name": "Transaction",
      "sort": 10,
      "type": "text",
      "title": {
        "show": true,
        "level": 1
      },
      "text": {
        "content": "<h2>Prix</h2><p><span style=\"font-family:sans-serif\">Prix de base × marge de base + % du marchand</span></p><h2>Négocier le prix</h2><div><table style=\"text-align:center\" border=\"0\"><thead><tr style=\"border-bottom:1px solid #999\"><th><p>Nb. succès</p></th><th>Achat</th><th>Vente</th></tr></thead><tbody><tr style=\"border-bottom:1px solid #999\"><td><p>[su]</p></td><td>prix - <strong>10%</strong></td><td>prix × <strong>1/4</strong></td></tr><tr style=\"border-bottom:1px solid #999\"><td><p>[su][su]</p></td><td>prix - <strong>15%</strong></td><td>prix × <strong>1/2</strong></td></tr><tr style=\"border-bottom:1px solid #999\"><td><p>[su][su][su]</p></td><td>prix - <strong>20%</strong></td><td>prix × <strong>3/4</strong></td></tr><tr style=\"border-bottom:1px solid #999\"><td><p>[th][th][th] ou [de]</p></td><td colspan=\"2\">La transaction échoue, pb dans la marchandise (si marché noir : PJ doublé, descente de police...)</td></tr></tbody></table></div>",
        "format": 1
      },
      "system": {},

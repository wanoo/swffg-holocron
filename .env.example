# swffg-holocron — configuration (all secrets live here, never in the repo)

# --- web service -------------------------------------------------------------
PORT=8080
# Persistent dir for cache + session data (mount a volume / FS bucket here)
HOLOCRON_DATA_DIR=./data
# Secret used to sign session cookies (generate: openssl rand -hex 32)
SESSION_SECRET=change-me

# --- Foundry connection ------------------------------------------------------
# Public base URL of your Foundry (used for asset proxying and login validation)
# e.g. https://vtt.example.com or https://vtt.example.com/my-world-route
FOUNDRY_BASE_URL=https://your-foundry.example.com

# Mode sidecar (default): the service spawns the foundry-mcp-gateway Rust binary
# (vendor/foundry-mcp, fetched by `npm install` via scripts/fetch-gateway.mjs;
# override the path with FOUNDRY_GATEWAY_BIN, the local port with
# FOUNDRY_GATEWAY_PORT, default 8788).
# JSON array of credentials for a GM-level bot user (_id = 16-char user id):
FOUNDRY_CREDENTIALS_JSON=[{"_id":"my-world","hostname":"your-foundry.example.com/route","userid":"BOTUSERID12345","password":"..."}]

# Mode http (optional): external foundry-mcp-gateway URL, including the
# /mcp-<secret> path. Takes precedence over the sidecar when set.
FOUNDRY_MCP_URL=

# --- legacy key access (scripts, macros, emergency) ---------------------------
# Optional. If unset, the corresponding key-based routes are disabled.
GM_KEY=
PLAYER_KEY=

# --- tuning --------------------------------------------------------------------
# Background sync interval (seconds)
SYNC_INTERVAL_S=300
# Name of the Foundry journal holding the campaign config
CONFIG_JOURNAL_NAME=⚙️ Holocron Config
# CORS
CORS_ORIGIN=*
